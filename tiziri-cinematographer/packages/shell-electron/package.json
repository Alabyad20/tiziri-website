{
  "name": "@tiziri/shell-electron",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "author": "Tiziri",
  "description": "Thin, hardened Electron shell hosting the React/Vite renderer over an allow-listed IPC surface.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "self-test": "npm run build && node ./scripts/self-test-run.mjs",
    "package:dir": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@tiziri/core": "*",
    "@tiziri/library": "*",
    "@tiziri/shared": "*"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^7.3.6"
  }
}
